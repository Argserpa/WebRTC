# ============ STREAMING ============
INPUT=/dev/video0
USE_NVENC=false
VIDEO_SCALE=1920:1080

# Duración de cada segmento de grabación en segundos (1800 = 30 min)
SEGMENT_DURATION=1800

# ============ TURN (opcional) ============
TURN_SERVER_HOST=192.168.1.45
TURN_SERVER_PORT=3478
TURN_SERVER_USER=turnuser
TURN_SERVER_PASS=turnpass
TURN_SERVER_REALM=yourdomain.com